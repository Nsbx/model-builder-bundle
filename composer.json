{
    "name": "nsbx/model-builder-bundle",
    "type": "symfony-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Nicolas Bondoux"
        }
    ],
    "require": {
        "php": ">=8.1",
        "symfony/property-access": "^6.2||^7.0"
    },
    "require-dev": {
        "symfony/test-pack": "^1.1",
        "symfony/yaml": "^6.2||^7.0"
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "Nsbx\\Bundle\\ModelBuilder\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nsbx\\Bundle\\ModelBuilder\\Tests\\": "tests/"
        }
    }
}
